# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# Higgsfield AI — format: apikey:apisecret (from platform.higgsfield.ai)
VITE_HIGGSFIELD_KEY=

# Pinterest — Bearer token (from developers.pinterest.com)
VITE_PINTEREST_TOKEN=

# Google Gemini / Imagen — API key (from aistudio.google.com)
VITE_GEMINI_KEY=
